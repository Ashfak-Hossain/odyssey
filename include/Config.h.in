/**
 * @file Config.h.in
 * @brief Configuration header template for the Odyssey project.
 * This file is processed by CMake to generate a Config.h file in the build dir.
 * It defines constants used in the project.
 */


#ifndef CONFIG_H
#define CONFIG_H

#define PLATFORM_@PLATFORM_NAME@ 1

constexpr int  WINDOW_WIDTH   = 900;
constexpr int  WINDOW_HEIGHT  = 700;
constexpr char WINDOW_TITLE[] = "Odyssey";

constexpr float GRAVITY    = -600.0f; // gravity acceleration (pixels/s^2) 
constexpr float JUMP_FORCE = 320.0f;  // initial jump velocity (pixels/s)
constexpr float MOVE_SPEED = 200.0f;  // horizontal movement speed (pixels/s)

constexpr float PLAYER_WIDTH  = 20.0f;
constexpr float PLAYER_HEIGHT = 40.0f;

constexpr float GROUND_Y = 0.0f;

#endif